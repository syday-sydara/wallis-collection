// =====================================
// GENERATOR & DATASOURCE
// =====================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================
// USER
// =====================================

model User {
  id        String   @id @default(cuid())
  name      String?
  phone     String?  @unique
  email     String?  @unique

  orders          Order[]
  whatsappOrders  WhatsAppOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =====================================
// PRODUCT CATALOG
// =====================================

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?

  fabricType  FabricType
  color       String?
  pattern     String?

  isActive    Boolean  @default(true)
  deletedAt   DateTime?

  images      ProductImage[]
  variants    ProductVariant[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])

  name      String
  sku       String?  @unique

  price     Int      // in kobo
  stockQty  Int      @default(0)

  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reservations StockReservation[]
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])

  url       String
  alt       String?

  createdAt DateTime @default(now())
}

enum FabricType {
  WAX
  SUPERWAX
  HOLLAND
  ABAYA
  LACE
  GEORGE
  ATIKU
  KAFTAN
  OTHER
}

// =====================================
// INVENTORY (ANTI-OVERSELLING)
// =====================================

model StockReservation {
  id        String         @id @default(cuid())

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  orderId   String?
  order     Order?         @relation(fields: [orderId], references: [id])

  quantity  Int

  status    ReservationStatus @default(ACTIVE)

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([variantId])
  @@index([orderId])
}

enum ReservationStatus {
  ACTIVE
  CONSUMED
  RELEASED
}

// =====================================
// ORDER SYSTEM
// =====================================

model Order {
  id          String      @id @default(cuid())

  userId      String?
  user        User?       @relation(fields: [userId], references: [id])

  phoneNumber String

  // Address (Nigeria-friendly)
  addressLine1 String
  addressLine2 String?
  city         String?
  state        String
  lga          String?
  landmark     String?
  deliveryNote String?

  // Financials
  subtotal     Int
  deliveryFee  Int @default(0)
  discount     Int @default(0)
  totalAmount  Int

  currency     String @default("NGN")

  // Payment summary (important)
  paymentMethod PaymentProvider
  paymentStatus PaymentStatus @default(PENDING)

  status        OrderStatus   @default(PENDING)

  items       OrderItem[]
  payments    Payment[]
  shipment    Shipment?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phoneNumber, createdAt])
  @@index([status, createdAt])
  @@index([paymentStatus, createdAt])
}

// =====================================
// ORDER ITEMS
// =====================================

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  quantity  Int      @default(1)
  priceAtTime Int

  createdAt DateTime @default(now())
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// =====================================
// PAYMENTS (MANUAL-FIRST)
// =====================================

model Payment {
  id        String          @id @default(cuid())

  orderId   String
  order     Order           @relation(fields: [orderId], references: [id])

  provider  PaymentProvider
  amount    Int
  currency  String          @default("NGN")

  status    PaymentStatus   @default(PENDING)

  reference String?         @unique

  // Bank transfer fields
  paidByName String?
  paidAt     DateTime?
  proofUrl   String?

  // Admin verification
  verifiedBy String?
  verifiedAt DateTime?

  notes      String?

  createdAt  DateTime       @default(now())

  @@index([status, createdAt])
}

enum PaymentProvider {
  BANK_TRANSFER
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  PENDING
  AWAITING_CONFIRMATION
  SUCCESS
  FAILED
}

// =====================================
// SHIPPING / DELIVERY
// =====================================

model Shipment {
  id        String   @id @default(cuid())
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id])

  provider  String?
  trackingNumber String?

  status    ShipmentStatus @default(PENDING)

  shippedAt   DateTime?
  deliveredAt DateTime?

  createdAt DateTime @default(now())
}

enum ShipmentStatus {
  PENDING
  SHIPPED
  IN_TRANSIT
  DELIVERED
  FAILED
}

// =====================================
// WHATSAPP COMMERCE
// =====================================

model WhatsAppOrder {
  id          String              @id @default(cuid())

  phoneNumber String

  userId      String?
  user        User?               @relation(fields: [userId], references: [id])

  status      WhatsAppOrderStatus @default(PENDING)

  // Address
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  lga          String?
  landmark     String?

  paymentMethod WhatsAppPaymentMethod?
  deliveryMethod DeliveryMethod @default(DELIVERY)

  notes         String?
  lastMessageAt DateTime?

  items       WhatsAppOrderItem[]

  finalOrderId String?
  finalOrder   Order?            @relation(fields: [finalOrderId], references: [id])

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([phoneNumber, createdAt])
  @@index([status, createdAt])
  @@index([status, lastMessageAt])
}

model WhatsAppOrderItem {
  id              String        @id @default(cuid())
  whatsappOrderId String
  order           WhatsAppOrder @relation(fields: [whatsappOrderId], references: [id])

  variantId       String
  variant         ProductVariant @relation(fields: [variantId], references: [id])

  quantity        Int           @default(1)
  priceAtTime     Int

  createdAt       DateTime      @default(now())
}

enum WhatsAppOrderStatus {
  PENDING
  CONFIRMED
  PAID
  CANCELLED
}

enum WhatsAppPaymentMethod {
  BANK_TRANSFER
  CASH_ON_DELIVERY
}

enum DeliveryMethod {
  DELIVERY
  PICKUP
}

// =====================================
// AUDIT LOG (IMPORTANT)
// =====================================

model AuditLog {
  id        String   @id @default(cuid())

  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  actorType ActorType

  action    String

  entityType String
  entityId   String

  metadata  Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
}

enum ActorType {
  USER
  ADMIN
  SYSTEM
}

model OrderStatusHistory {
  id        String   @id @default(cuid())
  orderId   String
  from      String
  to        String
  createdAt DateTime @default(now())
}