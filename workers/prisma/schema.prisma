// =====================================
// GENERATOR & DATASOURCE
// =====================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================
// ENUMS
// =====================================

enum FabricType {
  WAX
  SUPERWAX
  HOLLAND
  ABAYA
  LACE
  GEORGE
  ATIKU
  KAFTAN
  OTHER
}

enum ReservationStatus {
  ACTIVE
  CONSUMED
  RELEASED
}

enum OrderStatus {
  PENDING
  PAID
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  AWAITING_CONFIRMATION
  SUCCESS
  FAILED
}

enum ShipmentStatus {
  PENDING
  SHIPPED
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum DeliveryMethod {
  DELIVERY
  PICKUP
}

enum ActorType {
  USER
  ADMIN
  SYSTEM
}

enum Currency {
  NGN
}

enum OrderChannel {
  WHATSAPP
  WEB
  IN_STORE
  OTHER
}

// =====================================
// IDENTITY
// =====================================

model User {
  id    String  @id @default(cuid())
  name  String?
  phone String? @unique
  email String? @unique

  customer Customer?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  AuditLog AuditLog[]
}

model Customer {
  id           String  @id @default(cuid())
  userId       String? @unique
  user         User?   @relation(fields: [userId], references: [id])
  primaryPhone String

  orders Order[]

  createdAt DateTime @default(now())
}

// =====================================
// ADDRESS
// =====================================

model Address {
  id       String  @id @default(cuid())
  line1    String
  line2    String?
  city     String?
  state    String
  lga      String?
  landmark String?

  // Back‑relation to Order.shippingAddress
  orders Order[]

  createdAt DateTime @default(now())
}

// =====================================
// PRODUCT CATALOG
// =====================================

model Product {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?

  fabricType FabricType
  color      String?
  pattern    String?

  isActive  Boolean   @default(true)
  deletedAt DateTime?

  images   ProductImage[]
  variants ProductVariant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])

  name String
  sku  String @unique

  price    Int
  stockQty Int @default(0)

  isActive Boolean @default(true)

  reservations StockReservation[]
  OrderItem    OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, isActive])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  url String
  alt String?

  createdAt DateTime @default(now())
}

// =====================================
// INVENTORY
// =====================================

model StockReservation {
  id String @id @default(cuid())

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  quantity Int

  status    ReservationStatus @default(ACTIVE)
  expiresAt DateTime
  createdAt DateTime          @default(now())

  @@index([variantId])
  @@index([orderId])
  @@index([status, expiresAt])
}

// =====================================
// PROVIDERS (REPLACES ENUMS)
// =====================================

model PaymentProvider {
  id       String  @id @default(cuid())
  code     String  @unique
  name     String
  isActive Boolean @default(true)

  payments Payment[]
}

model ShipmentProvider {
  id       String  @id @default(cuid())
  code     String  @unique
  name     String
  isActive Boolean @default(true)

  shipments Shipment[]
}

// =====================================
// ORDER SYSTEM (UNIFIED)
// =====================================

model Order {
  id String @id @default(cuid())

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  channel OrderChannel @default(WHATSAPP)

  phoneNumber String

  addressId String?
  address   Address? @relation(fields: [addressId], references: [id])

  deliveryMethod DeliveryMethod @default(DELIVERY)
  deliveryNote   String?

  subtotal    Int
  deliveryFee Int @default(0)
  discount    Int @default(0)
  totalAmount Int

  currency Currency @default(NGN)

  paymentStatus PaymentStatus @default(PENDING)
  status        OrderStatus   @default(PENDING)
  cancelReason  String?

  items         OrderItem[]
  payments      Payment[]
  shipment      Shipment?
  reservations  StockReservation[]
  statusHistory OrderStatusHistory[]

  // WhatsApp-specific fields (nullable)
  whatsappSessionId String?
  lastMessageAt     DateTime?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phoneNumber, createdAt])
  @@index([status, paymentStatus, createdAt])
  @@index([channel])
}

// =====================================
// ORDER ITEMS
// =====================================

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  quantity    Int @default(1)
  priceAtTime Int

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([variantId])
}

// =====================================
// PAYMENTS
// =====================================

model Payment {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  providerId String
  provider   PaymentProvider @relation(fields: [providerId], references: [id])

  amount   Int
  currency Currency @default(NGN)

  status PaymentStatus @default(PENDING)

  reference     String? @unique
  transactionId String? @unique

  paidByName String?
  paidAt     DateTime?
  proofUrl   String?

  verifiedBy String?
  verifiedAt DateTime?

  notes String?

  createdAt DateTime @default(now())

  @@index([status, createdAt])
  @@index([orderId, status])
  @@index([reference])
}

// =====================================
// SHIPPING
// =====================================

model Shipment {
  id      String @id @default(cuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  providerId     String?
  provider       ShipmentProvider? @relation(fields: [providerId], references: [id])
  trackingNumber String?

  status ShipmentStatus @default(PENDING)

  shippedAt   DateTime?
  deliveredAt DateTime?

  createdAt DateTime @default(now())
}

// =====================================
// AUDIT LOG
// =====================================

model AuditLog {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  actorType ActorType
  action    String

  entityType String
  entityId   String

  metadata Json?

  traceId String?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([action, createdAt])
}

// =====================================
// ORDER STATUS HISTORY
// =====================================

model OrderStatusHistory {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  from OrderStatus
  to   OrderStatus

  actorType ActorType @default(SYSTEM)

  createdAt DateTime @default(now())

  @@index([orderId])
}
