generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUMS
//////////////////////

enum UserRole {
  USER
  ADMIN
}

enum PaymentStatus {
  INITIATED
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  REVIEW
  REFUNDED
  CHARGEBACK
}

enum OrderStatus {
  CREATED
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum Currency {
  NGN
  USD
  EUR
}

enum PaymentMethod {
  CARD
  TRANSFER
  CASH
}

enum ShippingType {
  STANDARD
  EXPRESS
  PICKUP
}

enum FraudDecision {
  APPROVED
  REVIEW
  BLOCKED
}

//////////////////////
// USER
//////////////////////

model User {
  id    String   @id @default(cuid())
  email String   @unique
  name  String?
  role  UserRole @default(USER)

  passwordHash  String?
  phone         String? @unique
  phoneVerified Boolean @default(false)
  emailVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders         Order[]
  addresses      Address[]
  auditEvents    AuditEvent[]
  securityEvents SecurityEvent[]

  @@index([email])
}

//////////////////////
// PRODUCT CATALOG
//////////////////////

model Product {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?

  basePrice Int?

  isArchived Boolean   @default(false)
  deletedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images     ProductImage[]
  variants   ProductVariant[]
  orderItems OrderItem[]

  @@index([slug])
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int     @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])

  name  String
  sku   String @unique
  price Int

  stock         Int @default(0)
  reservedStock Int @default(0)
  /// reservedStock must never exceed stock

  attributes Json?

  orderItems OrderItem[]
  stockLogs  StockLog[]

  @@index([productId])
  @@index([sku, productId])
}

//////////////////////
// ORDERS
//////////////////////

model Order {
  id String @id @default(cuid())

  email    String
  phone    String
  fullName String

  subtotal       Int
  shippingCost   Int
  discountAmount Int @default(0)
  total          Int

  currency      Currency      @default(NGN)
  paymentMethod PaymentMethod
  orderStatus   OrderStatus   @default(CREATED)

  shippingType ShippingType

  shippingAddress Json
  cartSnapshot    Json

  fraudScore    Int?
  fraudSignals  Json?
  fraudDecision FraudDecision?

  ipAddress String?
  userAgent String?

  deliveryNotes String?
  assignedRider String?
  deliveredAt   DateTime?

  idempotencyKey String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  items    OrderItem[]
  payments Payment[]

  @@unique([idempotencyKey, userId])
  @@index([createdAt])
  @@index([userId])
  @@index([userId, createdAt])
  @@index([orderStatus, createdAt])
}

model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  name       String
  image      String?
  attributes Json?

  quantity  Int
  unitPrice Int

  @@index([orderId])
}

//////////////////////
// PAYMENTS
//////////////////////

model Payment {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  provider  String
  reference String

  providerTransactionId String?

  idempotencyKey String?

  amount   Int
  currency Currency

  status PaymentStatus

  channel String?

  paidAt DateTime?

  bankName          String?
  accountNumber     String?
  accountName       String?
  transferReference String?

  verifiedAt           DateTime?
  verificationAttempts Int       @default(0)
  lastCheckedAt        DateTime?
  nextVerificationAt   DateTime?

  attempt Int @default(1)

  raw Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, reference])
  @@index([orderId])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([orderId, status])
  @@index([providerTransactionId])
}

//////////////////////
// ADDRESS
//////////////////////

model Address {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  fullName String
  phone    String

  line1    String
  line2    String?
  landmark String?

  city  String
  state String
  lga   String?

  postalCode String?
  country    String  @default("Nigeria")

  latitude  Float?
  longitude Float?

  deliveryInstructions String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}

//////////////////////
// PAYMENT LOG
//////////////////////

model PaymentLog {
  id String @id @default(cuid())

  provider String
  payload  Json

  processed Boolean @default(false)

  createdAt DateTime @default(now())
}

//////////////////////
// OTP
//////////////////////

model OTP {
  id String @id @default(cuid())

  phone String
  code  String

  expiresAt DateTime
  used      Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([phone])
}

//////////////////////
// AUDIT
//////////////////////

model AuditEvent {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  action     String
  resource   String?
  resourceId String?

  metadata Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

//////////////////////
// STOCK LOG
//////////////////////

model StockLog {
  id String @id @default(cuid())

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  change Int
  reason String?

  createdAt DateTime @default(now())

  @@index([variantId])
  @@index([createdAt])
}

//////////////////////
// SECURITY EVENTS
//////////////////////

model SecurityEvent {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  type      String
  message   String
  ip        String @db.VarChar(45)
  userAgent String

  timestamp DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([timestamp])
}
