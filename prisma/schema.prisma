// ------------------------------------------------------
// GENERATOR & DATASOURCE
// ------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================
// USER
// =====================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  auditLogs AuditLog[] @relation("AuditLogUser")
}

// ------------------------------------------------------
// PRODUCT CATALOG
// ------------------------------------------------------

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  variants ProductVariant[]
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  sku       String   @unique
  name      String
  price     Int
  currency  String
  stockQty  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product      Product            @relation(fields: [productId], references: [id], onDelete: Restrict)
  reservations StockReservation[]

  @@index([productId])
}

// ------------------------------------------------------
// RESERVATION-DRIVEN INVENTORY
// ------------------------------------------------------

model StockReservation {
  id        String            @id @default(cuid())
  variantId String
  orderId   String?
  status    ReservationStatus @default(ACTIVE)
  quantity  Int
  expiresAt DateTime
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  order   Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([variantId])
  @@index([orderId])
}

enum ReservationStatus {
  ACTIVE
  CONSUMED
  RELEASED
}

// =====================================
// ORDER SYSTEM
// =====================================

model Order {
  id          String      @id @default(cuid())

  userId      String?
  user        User?       @relation(fields: [userId], references: [id])

  phoneNumber String

  // Address (Nigeria-friendly)
  addressLine1 String
  addressLine2 String?
  city         String?
  state        String
  lga          String?
  landmark     String?
  deliveryNote String?

  // Financials
  subtotal     Int
  deliveryFee  Int @default(0)
  discount     Int @default(0)
  totalAmount  Int

  currency     String @default("NGN")

  // Payment summary (important)
  paymentMethod PaymentProvider
  paymentStatus PaymentStatus @default(PENDING)

  status        OrderStatus   @default(PENDING)

  items       OrderItem[]
  payments    Payment[]
  shipment    Shipment?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phoneNumber, createdAt])
  @@index([status, createdAt])
  @@index([paymentStatus, createdAt])
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  reason    String?
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// ------------------------------------------------------
// PAYMENTS
// ------------------------------------------------------

model Payment {
  id        String          @id @default(cuid())

  orderId   String
  order     Order           @relation(fields: [orderId], references: [id])

  provider  PaymentProvider
  amount    Int
  currency  String          @default("NGN")

  status    PaymentStatus   @default(PENDING)

  reference String?         @unique

  // Bank transfer fields
  paidByName String?
  paidAt     DateTime?
  proofUrl   String?

  // Admin verification
  verifiedBy String?
  verifiedAt DateTime?

  notes      String?

  createdAt  DateTime       @default(now())

  @@index([status, createdAt])
}

enum PaymentProvider {
  BANK_TRANSFER
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  PENDING
  AWAITING_CONFIRMATION
  SUCCESS
  FAILED
}

// =====================================
// SHIPPING / DELIVERY
// =====================================

model Shipment {
  id        String   @id @default(cuid())
  orderId   String   @unique
  order     Order    @relation(fields: [orderId], references: [id])

  provider  String?
  trackingNumber String?

  status    ShipmentStatus @default(PENDING)

  shippedAt   DateTime?
  deliveredAt DateTime?

  createdAt DateTime @default(now())
}

enum ShipmentStatus {
  PENDING
  SHIPPED
  IN_TRANSIT
  DELIVERED
  FAILED
}

// ------------------------------------------------------
// WHATSAPP SESSION + MESSAGES
// ------------------------------------------------------

model WhatsAppOrder {
  id          String              @id @default(cuid())

  phoneNumber String

  userId      String?
  user        User?               @relation(fields: [userId], references: [id])

  status      WhatsAppOrderStatus @default(PENDING)

  // Address
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  lga          String?
  landmark     String?

  paymentMethod WhatsAppPaymentMethod?
  deliveryMethod DeliveryMethod @default(DELIVERY)

  notes         String?
  lastMessageAt DateTime?

  items       WhatsAppOrderItem[]

  finalOrderId String?
  finalOrder   Order?            @relation(fields: [finalOrderId], references: [id])

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([phoneNumber, createdAt])
  @@index([status, createdAt])
  @@index([status, lastMessageAt])
}

model WhatsAppOrderItem {
  id              String        @id @default(cuid())
  whatsappOrderId String
  order           WhatsAppOrder @relation(fields: [whatsappOrderId], references: [id])

  variantId       String
  variant         ProductVariant @relation(fields: [variantId], references: [id])

  quantity        Int           @default(1)
  priceAtTime     Int

  createdAt       DateTime      @default(now())
}

enum WhatsAppOrderStatus {
  PENDING
  CONFIRMED
  PAID
  CANCELLED
}

enum WhatsAppPaymentMethod {
  BANK_TRANSFER
  CASH_ON_DELIVERY
}

enum DeliveryMethod {
  DELIVERY
  PICKUP
}

// ------------------------------------------------------
// AUDIT LOG
// ------------------------------------------------------

model AuditLog {
  id        String   @id @default(cuid())

  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  actorType ActorType

  action    String

  entityType String
  entityId   String
  metadata   Json      @default("{}")
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  user User? @relation("AuditLogUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
}

enum ActorType {
  USER
  ADMIN
  SYSTEM
}

model OrderStatusHistory {
  id        String   @id @default(cuid())
  to        String
  createdAt DateTime @default(now())
}