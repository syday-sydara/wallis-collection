// ------------------------------------------------------
//  Prisma Schema for Wallis Collection Ecommerce System
// ------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // or mysql / sqlite depending on your setup
  url      = env("DATABASE_URL")
}

// -----------------------------
// Product Model
// -----------------------------
model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  priceNaira  Int
  images      String[]
  description String?
  category    String?
  stock       Int       @default(0)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  OrderItem   OrderItem[]
}

// -----------------------------
// Order Model
// -----------------------------
model Order {
  id             String         @id @default(cuid())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Customer Info
  email          String
  phone          String?

  // Shipping Info
  shippingType   ShippingType
  address        String?
  city           String?
  state          String?
  postalCode     String?
  courierPhone   String?
  trackingNumber String?

  // Payment Info
  paymentMethod  PaymentMethod
  paid           Boolean        @default(false)

  // Totals
  subtotal       Int
  total          Int

  // Relations
  items          OrderItem[]
}

// -----------------------------
// Order Item Model
// -----------------------------
model OrderItem {
  id        String   @id @default(cuid())

  order     Order    @relation(fields: [orderId], references: [id])
  orderId   String

  productId String
  name      String
  price     Int
  quantity  Int
  image     String?
}

// -----------------------------
// Enums
// -----------------------------
enum ShippingType {
  DELIVERY
  PICKUP
}

enum PaymentMethod {
  CARD
  BANK_TRANSFER
  PAY_ON_DELIVERY
}