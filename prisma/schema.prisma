generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUMS
//////////////////////

enum UserRole {
  USER
  ADMIN
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum OrderStatus {
  CREATED
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CARD
  TRANSFER
  CASH
}

enum ShippingType {
  STANDARD
  EXPRESS
  PICKUP
}

//////////////////////
// USER
//////////////////////

model User {
  id    String   @id @default(cuid())
  email String   @unique
  name  String?
  role  UserRole @default(USER)

  passwordHash String?
  phone        String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  addresses Address[]

  @@index([email])
}

//////////////////////
// PRODUCT
//////////////////////

model Product {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?

  isArchived Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  images   ProductImage[]
  variants ProductVariant[]

  @@index([slug])
  @@index([isArchived, createdAt])
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int     @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])

  name  String
  sku   String @unique
  price Int

  stock Int @default(0)

  attributes Json?

  orderItems OrderItem[]

  @@index([productId])
}

//////////////////////
// ORDERS
//////////////////////

model Order {
  id String @id @default(cuid())

  email    String
  phone    String
  fullName String

  subtotal       Int
  shippingCost   Int
  discountAmount Int @default(0)
  total          Int

  paymentMethod PaymentMethod
  orderStatus   OrderStatus @default(CREATED)

  shippingType ShippingType

  shippingAddress Json

  deliveryNotes String?
  deliveredAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String?
  user   User? @relation(fields: [userId], references: [id])

  items    OrderItem[]
  payments Payment[]

  @@index([createdAt])
  @@index([userId])
  @@index([orderStatus, createdAt])
}

model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order @relation(fields: [orderId], references: [id])

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  name       String
  image      String?
  attributes Json?

  quantity  Int
  unitPrice Int

  @@index([orderId])
}

//////////////////////
// PAYMENTS
//////////////////////

model Payment {
  id String @id @default(cuid())

  orderId String
  order   Order @relation(fields: [orderId], references: [id])

  provider  String
  reference String @unique

  amount Int

  status PaymentStatus

  paidAt DateTime?

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([status])
}

//////////////////////
// ADDRESS
//////////////////////

model Address {
  id String @id @default(cuid())

  userId String?
  user   User? @relation(fields: [userId], references: [id])

  fullName String
  phone    String

  line1 String
  line2 String?

  city  String
  state String

  country String @default("Nigeria")

  createdAt DateTime @default(now())

  @@index([userId])
}

//////////////////////
// OTP
//////////////////////

model OTP {
  id String @id @default(cuid())

  phone String
  code  String

  expiresAt DateTime
  used      Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([phone])
  @@index([expiresAt])
}