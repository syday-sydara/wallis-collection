generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUMS
//////////////////////

enum UserRole {
  USER
  ADMIN
}

enum PaymentStatus {
  INITIATED
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  REVIEW
  REFUNDED
  CHARGEBACK
}

enum OrderStatus {
  CREATED
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum Currency {
  NGN
  USD
  EUR
}

enum PaymentMethod {
  CARD
  TRANSFER
  CASH
}

enum ShippingType {
  STANDARD
  EXPRESS
  PICKUP
}

enum FraudDecision {
  APPROVED
  REVIEW
  BLOCKED
}

//////////////////////
// USER
//////////////////////

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      UserRole @default(USER)

  passwordHash  String?
  phone         String? @unique // E.164 format recommended
  phoneVerified Boolean @default(false)
  emailVerified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
}

//////////////////////
// PRODUCT CATALOG
//////////////////////

model Product {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?

  basePrice Int?

  isArchived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images   ProductImage[]
  variants ProductVariant[]

  @@index([slug])
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int     @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])

  name  String
  sku   String @unique
  price Int

  stock         Int @default(0)
  reservedStock Int @default(0)

  attributes Json?

  @@index([productId])
}

//////////////////////
// ORDERS
//////////////////////

model Order {
  id String @id @default(cuid())

  email    String
  phone    String
  fullName String

  subtotal       Int
  shippingCost   Int
  discountAmount Int @default(0)
  total          Int

  currency      Currency      @default(NGN)
  paymentMethod PaymentMethod
  orderStatus   OrderStatus   @default(CREATED)

  shippingType ShippingType

  // Snapshot
  shippingAddress Json
  cartSnapshot    Json

  // Fraud
  fraudScore    Int?
  fraudSignals  Json?
  fraudDecision FraudDecision?

  // Idempotency
  idempotencyKey String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String?
  user   User? @relation(fields: [userId], references: [id])

  items    OrderItem[]
  payments Payment[]

  @@index([createdAt])
  @@index([userId])
}

model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order @relation(fields: [orderId], references: [id])

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  name       String
  image      String?
  attributes Json?

  quantity  Int
  unitPrice Int

  @@index([orderId])
}

//////////////////////
// PAYMENTS (SOURCE OF TRUTH)
//////////////////////

model Payment {
  id String @id @default(cuid())

  orderId String
  order   Order @relation(fields: [orderId], references: [id])

  provider  String
  reference String

  providerTransactionId String?

  idempotencyKey String? @unique

  amount   Int
  currency Currency

  status PaymentStatus

  channel String?

  paidAt DateTime?

  // Nigeria resilience
  verifiedAt DateTime?
  verificationAttempts Int @default(0)
  lastCheckedAt DateTime?

  raw Json

  createdAt DateTime @default(now())

  @@unique([provider, reference])
  @@index([orderId])
  @@index([createdAt])
}

//////////////////////
// ADDRESS
//////////////////////

model Address {
  id String @id @default(cuid())

  userId String?
  user   User? @relation(fields: [userId], references: [id])

  fullName String
  phone    String

  line1    String
  line2    String?
  landmark String?

  city  String
  state String
  lga   String?

  postalCode String?
  country    String @default("Nigeria")

  deliveryInstructions String?

  createdAt DateTime @default(now())

  @@index([userId])
}

//////////////////////
// AUDIT
//////////////////////

model AuditEvent {
  id String @id @default(cuid())

  userId String?
  user   User? @relation(fields: [userId], references: [id])

  action     String
  resource   String?
  resourceId String?

  metadata Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

//////////////////////
// STOCK LOG
//////////////////////

model StockLog {
  id String @id @default(cuid())

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  change Int
  reason String?

  createdAt DateTime @default(now())

  @@index([variantId])
  @@index([createdAt])
}

//////////////////////
// SECURITY EVENTS
//////////////////////

model SecurityEvent {
  id String @id @default(cuid())

  userId String?
  user   User? @relation(fields: [userId], references: [id])

  type      String
  message   String
  ip        String
  userAgent String

  timestamp DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([timestamp])
}