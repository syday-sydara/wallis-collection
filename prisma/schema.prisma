generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUMS
//////////////////////

enum UserRole {
  USER
  ADMIN
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REVIEW
  REFUNDED
  CHARGEBACK
}

enum OrderStatus {
  CREATED
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum Currency {
  NGN
  USD
  EUR
}

enum PaymentMethod {
  CARD
  TRANSFER
  CASH
}

//////////////////////
// USER
//////////////////////

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      UserRole @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
}

//////////////////////
// PRODUCT CATALOG
//////////////////////

model Product {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?

  basePrice Int?

  isArchived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images   ProductImage[]
  variants ProductVariant[]

  @@index([slug])
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int     @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])

  name  String
  sku   String @unique
  price Int

  stock         Int @default(0)
  reservedStock Int @default(0) // future-safe for reservations

  attributes Json?

  @@index([productId])
}

//////////////////////
// ORDERS
//////////////////////

model Order {
  id        String   @id @default(cuid())

  email     String
  phone     String
  fullName  String

  subtotal       Int
  shippingCost   Int
  discountAmount Int @default(0)
  total          Int

  currency      Currency      @default(NGN)
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus
  orderStatus   OrderStatus

  shippingType String

  // Snapshot (CRITICAL)
  shippingAddress Json
  cartSnapshot    Json

  // Fraud tracking
  fraudScore   Int?
  fraudSignals Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String?
  user   User? @relation(fields: [userId], references: [id])

  items    OrderItem[]
  payments Payment[]

  @@index([paymentStatus])
  @@index([createdAt])
  @@index([userId])
}

model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order @relation(fields: [orderId], references: [id])

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  name       String
  image      String?
  attributes Json?

  quantity  Int
  unitPrice Int

  @@index([orderId])
}

//////////////////////
// PAYMENTS (LEDGER)
//////////////////////

model Payment {
  id        String   @id @default(cuid())

  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])

  provider  String
  reference String   @unique // provider reference

  providerTransactionId String?

  amount   Int
  currency Currency

  status PaymentStatus

  channel String?

  paidAt DateTime?

  raw Json

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([reference])
  @@index([createdAt])
}

//////////////////////
// ADDRESS (OPTIONAL USER STORAGE)
//////////////////////

model Address {
  id String @id @default(cuid())

  fullName   String
  phone      String
  line1      String
  line2      String?
  landmark   String?
  city       String
  state      String
  lga        String?
  postalCode String?
  country    String @default("Nigeria")

  deliveryInstructions String?

  createdAt DateTime @default(now())
}

//////////////////////
// AUDIT
//////////////////////

model AuditEvent {
  id        String   @id @default(cuid())

  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  action     String
  resource   String?
  resourceId String?

  metadata Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

//////////////////////
// STOCK LOG
//////////////////////

model StockLog {
  id        String   @id @default(cuid())

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  change    Int
  reason    String?

  createdAt DateTime @default(now())

  @@index([variantId])
  @@index([createdAt])
}