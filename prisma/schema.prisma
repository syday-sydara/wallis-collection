// ------------------------------------------------------
// GENERATOR & DATASOURCE
// ------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// ENUMS
// ------------------------------------------------------

enum ReservationStatus {
  ACTIVE
  CONSUMED
  RELEASED
  EXPIRED
}

enum PaymentStatus {
  INITIATED
  SUCCESS
  FAILED
  CONFIRMED
}

enum ActorType {
  USER
  SYSTEM
  ADMIN
  SERVICE
}

enum OrderStatus {
  PENDING
  AWAITING_PAYMENT
  PAID
  CANCELLED
  FULFILLED
}

// ------------------------------------------------------
// USER (OPTIONAL — KEEPING IT MINIMAL)
// ------------------------------------------------------

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  auditLogs AuditLog[] @relation("AuditLogUser")
}

// ------------------------------------------------------
// PRODUCT CATALOG
// ------------------------------------------------------

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  variants ProductVariant[]
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  sku       String   @unique
  name      String
  price     Int
  currency  String
  stockQty  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product      Product            @relation(fields: [productId], references: [id], onDelete: Restrict)
  reservations StockReservation[]

  @@index([productId])
}

// ------------------------------------------------------
// RESERVATION-DRIVEN INVENTORY
// ------------------------------------------------------

model StockReservation {
  id        String            @id @default(cuid())
  variantId String
  orderId   String?
  status    ReservationStatus @default(ACTIVE)
  quantity  Int
  expiresAt DateTime
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  order   Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([variantId])
  @@index([orderId])
  @@index([status, expiresAt])
}

// ------------------------------------------------------
// CUSTOMER
// ------------------------------------------------------

model Customer {
  id        String   @id @default(cuid())
  name      String?
  email     String?
  phone     String?  @unique
  createdAt DateTime @default(now())

  orders   Order[]
  sessions WhatsAppSession[]
}

// ------------------------------------------------------
// ORDERS (RESERVATION-DRIVEN)
// ------------------------------------------------------

model Order {
  id              String      @id @default(cuid())
  userId          String?
  customerId      String?
  externalRef     String?     @unique
  status          OrderStatus @default(PENDING)
  totalAmount     Int         @default(0)
  currency        String
  phone           String?
  phoneNormalized String
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  reservations  StockReservation[]
  payments      Payment[]
  statusHistory OrderStatusHistory[]

  // WhatsApp session relation
  whatsAppSessionId String?
  whatsAppSession   WhatsAppSession? @relation("WhatsAppOrderSession", fields: [whatsAppSessionId], references: [id])

  @@index([userId])
  @@index([customerId])
  @@index([status])
  @@index([whatsAppSessionId])
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  reason    String?
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// ------------------------------------------------------
// PAYMENTS
// ------------------------------------------------------

model Payment {
  id          String        @id @default(cuid())
  orderId     String
  provider    String
  providerRef String?       @unique
  status      PaymentStatus @default(INITIATED)
  amount      Int
  currency    String
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
}

// ------------------------------------------------------
// WHATSAPP SESSION + MESSAGES
// ------------------------------------------------------

model WhatsAppSession {
  id              String    @id @default(cuid())
  phone           String
  phoneNormalized String     @unique
  customerId      String?
  lastInboundAt   DateTime?
  lastOutboundAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  messages WhatsAppMessage[]
  orders   Order[]           @relation("WhatsAppOrderSession")
}

model WhatsAppMessage {
  id         String   @id @default(cuid())
  sessionId  String
  direction  String   // INBOUND | OUTBOUND
  body       String
  status     String   // QUEUED | SENDING | SENT | DELIVERED | READ | FAILED
  rawPayload Json?
  createdAt  DateTime @default(now())

  session WhatsAppSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// ------------------------------------------------------
// AUDIT LOG
// ------------------------------------------------------

model AuditLog {
  id         String    @id @default(cuid())
  requestId  String?
  traceId    String?
  userId     String?
  actorType  ActorType
  action     String
  entityType String
  entityId   String
  metadata   Json      @default("{}")
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  user User? @relation("AuditLogUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
}

// ------------------------------------------------------
// SMS LOGGING
// ------------------------------------------------------

model SmsMessage {
  id        String   @id @default(cuid())
  to        String
  text      String
  provider  String
  status    String   // QUEUED, SENT, FAILED_PRIMARY, SENT_FALLBACK, FAILED
  createdAt DateTime @default(now())
}

model MessageDeliveryLog {
  id          String   @id @default(cuid())
  messageId   String?  // WhatsApp messages have a DB id, SMS/Email may not
  channel     String   // "whatsapp" | "sms" | "email"
  status      String   // "SENT" | "FAILED" | "FALLBACK" | "RETRY" | "QUEUED"
  error       String?  // error message if failed
  payload     Json?    // raw payload sent to provider
  metadata    Json?    // extra info (latency, provider response, etc.)
  createdAt   DateTime @default(now())

  // Optional relation to WhatsAppMessage
  whatsAppMessage WhatsAppMessage? @relation(fields: [messageId], references: [id])
}
