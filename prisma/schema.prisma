generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  role       String   @default("USER")
  risk_score Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sessions   Session[]
  devices    Device[]
  orders     Order[]
  events     SecurityEvent[]
}

model Session {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  @@index([userId])
}

model Device {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  deviceName String?
  lastIp     String?
  lastSeenAt DateTime @default(now())

  @@index([userId])
}

model SecurityEvent {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  type      String
  message   String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Product {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  basePrice   Int       // in Kobo
  stock       Int       @default(0)
  isArchived  Boolean   @default(false)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  images      ProductImage[]
  variants    ProductVariant[]
  inventory   InventoryMovement[]

  @@index([deletedAt])
  @@index([isArchived])
}

model ProductImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  product   Product  @relation(fields: [productId], references: [id])
  productId String
}

model ProductVariant {
  id        String   @id @default(cuid())
  name      String
  sku       String   @unique
  price     Int      // in Kobo
  product   Product  @relation(fields: [productId], references: [id])
  productId String
}

model InventoryMovement {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  change    Int
  reason    String
  reference String?
  createdAt DateTime @default(now())
}

model Order {
  id                String   @id @default(cuid())
  email             String
  phone             String
  fullName          String
  total             Int      // in Kobo
  paymentMethod     String
  paymentStatus     String
  orderStatus       String
  shippingType      String
  shippingState     String
  shippingCost      Int      // in Kobo
  address           String?
  city              String?
  state             String?
  cartSnapshot      Json
  checkoutSessionId String?  @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  userId            String?
  user              User?    @relation(fields: [userId], references: [id])
  items             OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  name      String
  image     String?
  variants  Json
  quantity  Int
  price     Int     // in Kobo
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String
}

model FraudRule {
  id          String   @id @default(cuid())
  name        String
  description String?
  weight      Int       // how much this rule contributes to risk score
  enabled     Boolean   @default(true)
  condition   Json      // JSON expression describing the rule
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model FraudEvent {
  id        String   @id @default(cuid())
  orderId   String?
  ip        String?
  email     String?
  signal    String
  metadata  Json?
  createdAt DateTime @default(now())
}
