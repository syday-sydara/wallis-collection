generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUMS
//////////////////////

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
  BANNED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  REVIEW
  CHARGEBACK
  EXPIRED
  PARTIAL
}

enum OrderStatus {
  CREATED
  PENDING_PAYMENT
  REVIEW
  CONFIRMED
  PACKING
  SHIPPED
  DELIVERED
  RETURN_REQUESTED
  RETURNED
  FAILED_DELIVERY
  CANCELLED
}

enum PaymentMethod {
  CARD
  TRANSFER
  CASH
}

enum ShippingType {
  STANDARD
  EXPRESS
  PICKUP
}

enum OtpType {
  LOGIN
  VERIFY_PHONE
  RESET_PASSWORD
  ORDER_CONFIRMATION
}

enum Currency {
  NGN
  USD
  GBP
}

enum PaymentProvider {
  PAYSTACK
  MONNIFY
  BANK_TRANSFER
}

enum FulfillmentStatus {
  PENDING
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
}

//////////////////////
// USER
//////////////////////

model User {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?

  role   UserRole   @default(USER)
  status UserStatus @default(ACTIVE)

  passwordHash    String?
  phone           String?
  emailVerifiedAt DateTime?

  risk_score        Int    @default(0)
  permissions       Json?
  deniedPermissions Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  addresses Address[]
  sessions  Session[]
  devices   Device[]

  auditLogs AuditLog[] @relation("UserAuditLogs")

  @@index([email])
  @@index([phone])
}

//////////////////////
// CATEGORY
//////////////////////

model Category {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  products Product[] @relation("ProductCategories")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////
// PRODUCT
//////////////////////

model Product {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?

  basePrice Int?

  isArchived  Boolean   @default(false)
  isPublished Boolean   @default(false)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images   ProductImage[]
  variants ProductVariant[]

  categories Category[] @relation("ProductCategories")

  @@index([slug])
  @@index([isArchived, createdAt])
  @@index([isPublished, publishedAt])
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int     @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])

  name  String
  sku   String @unique
  price Int

  stock         Int @default(0)
  reservedStock Int @default(0)

  compareAtPrice Int?
  costPrice      Int?

  attributes Json?

  orderItems OrderItem[]
  stockLogs  StockLog[]

  @@index([productId])
}

//////////////////////
// STOCK LOG
//////////////////////

model StockLog {
  id        String         @id @default(cuid())
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  change Int
  reason String

  createdAt DateTime @default(now())

  @@index([variantId])
}

//////////////////////
// ORDERS
//////////////////////

model Order {
  id String @id @default(cuid())

  email    String
  phone    String
  fullName String

  subtotal       Int
  shippingCost   Int
  discountAmount Int @default(0)
  total          Int
  refundedAmount Int @default(0)

  currency      Currency      @default(NGN)
  paymentMethod PaymentMethod
  orderStatus   OrderStatus   @default(CREATED)

  paymentStatus   PaymentStatus    @default(PENDING)
  paymentProvider PaymentProvider?
  fraudScore      Int              @default(0)

  shippingType    ShippingType
  shippingAddress Json

  deliveryNotes String?
  deliveredAt   DateTime?

  isPaid Boolean @default(false)

  trackingNumber String?
  carrier        String?

  idempotencyKey String? @unique

  cartSnapshot Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  items         OrderItem[]
  payments      Payment[]
  fulfillments  Fulfillment[]   // FIXED RELATION

  @@index([createdAt])
  @@index([userId])
  @@index([orderStatus, createdAt])
}

model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  name       String
  image      String?
  attributes Json?

  quantity  Int
  unitPrice Int

  @@index([orderId])
}

//////////////////////
// PAYMENTS
//////////////////////

model Payment {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  provider  String
  reference String @unique

  amount Int
  fee    Int?

  currency Currency @default(NGN)

  status PaymentStatus @default(PENDING)

  channel String?
  raw     Json?

  paidAt    DateTime?
  settledAt DateTime?

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([status])
}

//////////////////////
// ADDRESS
//////////////////////

model Address {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  fullName String
  phone    String

  line1 String
  line2 String?

  city       String
  state      String
  lga        String?
  postalCode String?

  country String @default("Nigeria")

  createdAt DateTime @default(now())

  @@index([userId])
}

//////////////////////
// OTP
//////////////////////

model OTP {
  id String @id @default(cuid())

  phone String
  code  String

  type OtpType @default(LOGIN)

  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)

  createdAt DateTime @default(now())

  @@index([phone])
  @@index([expiresAt])
}

//////////////////////
// SESSIONS
//////////////////////

model Session {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  ipAddress  String?
  userAgent  String?
  deviceId   String?
  createdAt  DateTime  @default(now())
  lastActive DateTime  @default(now())
  revokedAt  DateTime?

  riskScore Int @default(0)

  @@index([userId])
  @@index([deviceId])
}

//////////////////////
// DEVICES
//////////////////////

model Device {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  deviceFingerprint String
  userAgent         String?
  lastIpAddress     String?

  trusted   Boolean  @default(false)
  createdAt DateTime @default(now())
  lastSeen  DateTime @default(now())

  @@unique([userId, deviceFingerprint])
  @@index([userId])
}

//////////////////////
// AUDIT LOG
//////////////////////

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  actorType  String
  actorId    String?
  resource   String?
  resourceId String?
  metadata   Json?
  createdAt  DateTime @default(now())
  userId     String?
  user       User?    @relation("UserAuditLogs", fields: [userId], references: [id])
}

//////////////////////
// SECURITY CENTER (v3)
//////////////////////

model SecurityEvent {
  id        String   @id @default(cuid())
  version   Int      @default(3)

  type      String
  message   String
  severity  String
  category  String?
  context   String?
  source    String?
  requestId String?

  actorType String
  actorId   String?

  orderId       String?
  fulfillmentId String?
  riderId       String?

  riskScore Int? @default(0)
  tags      String[] @default([])

  ip        String?
  userAgent String?

  metadata  Json?

  timestamp DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([type])
  @@index([severity])
  @@index([category])
  @@index([actorType])
  @@index([actorId])
  @@index([orderId])
  @@index([fulfillmentId])
  @@index([riderId])
  @@index([timestamp])
}

//////////////////////
// FRAUD / RISK
//////////////////////

model FraudEvent {
  id        String   @id @default(cuid())
  signal    String
  orderId   String?
  userId    String?
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([userId])
  @@index([signal])
}

model AlertEvent {
  id        String   @id @default(cuid())
  event     String
  userId    String?
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([event])
  @@index([userId])
}

model RiskEvent {
  id        String   @id @default(cuid())
  orderId   String?
  userId    String?
  riskScore Int
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([userId])
  @@index([riskScore])
}

//////////////////////
// SESSION / DEVICE EVENTS
//////////////////////

model SessionEvent {
  id        String   @id @default(cuid())
  sessionId String?
  userId    String?
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([userId])
}

model DeviceEvent {
  id        String   @id @default(cuid())
  deviceId  String?
  userId    String?
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([deviceId])
  @@index([userId])
}

//////////////////////
// FULFILLMENT
//////////////////////

model Fulfillment {
  id        String            @id @default(cuid())
  orderId   String
  order     Order             @relation(fields: [orderId], references: [id])
  carrier   String?
  tracking  String?
  status    FulfillmentStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}
