generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUMS
//////////////////////

enum UserRole {
  USER
  ADMIN
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderStatus {
  CREATED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

//////////////////////
// USER & AUTH
//////////////////////

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      UserRole @default(USER)
  riskScore Int      @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  sessions Session[]
  devices  Device[]
  orders   Order[]
  events   SecurityEvent[]

  @@index([email])
  @@index([deletedAt])
}

model Session {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  ipAddress String?
  userAgent String?

  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  expiresAt  DateTime

  @@index([userId])
  @@index([expiresAt])
}

model Device {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  fingerprint String?  @unique
  deviceName  String?
  lastIp      String?
  lastSeenAt  DateTime @default(now())

  @@index([userId])
}

model SecurityEvent {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  type      String
  message   String
  severity  String   @default("low")
  metadata  Json?

  ip        String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

//////////////////////
// PRODUCT CATALOG
//////////////////////

model Product {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?

  basePrice Int

  isArchived Boolean   @default(false)
  deletedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images     ProductImage[]
  variants   ProductVariant[]
  inventory  InventoryMovement[]
  orderItems OrderItem[]

  @@index([isArchived])
  @@index([deletedAt])
  @@index([createdAt, id])
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int     @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])

  name String
  sku  String @unique

  price    Int
  currency String @default("NGN")

  stock Int @default(0)

  attributes Json

  createdAt         DateTime            @default(now())
  InventoryMovement InventoryMovement[]

  @@index([productId])
}

//////////////////////
// INVENTORY (AUDIT LOG)
//////////////////////

model InventoryMovement {
  id String @id @default(cuid())

  productId String
  product   Product @relation(fields: [productId], references: [id])

  // ✅ NEW: track exact variant
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  change    Int
  reason    String
  reference String?

  createdAt DateTime @default(now())

  @@index([productId])
  @@index([variantId])
  @@index([createdAt])
  @@index([productId, createdAt, id])
}

//////////////////////
// ORDERS
//////////////////////

model Order {
  id        String   @id @default(cuid())

  email     String
  phone     String
  fullName  String

  total     Int
  currency  String   @default("NGN")

  paymentMethod String
  paymentStatus PaymentStatus
  orderStatus   OrderStatus

  currentStatusUpdatedAt DateTime?

  shippingType String
  shippingCost Int

  addressId String?
  address   Address? @relation(fields: [addressId], references: [id])

  cartSnapshot Json

  checkoutSessionId   String? @unique

  // 👇 ADD THESE TWO FIELDS
  paymentReference     String?   // Paystack + Monnify reference
  transactionReference String?   // Monnify-specific

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String?
  user   User? @relation(fields: [userId], references: [id])

  items         OrderItem[]
  statusHistory OrderStatusHistory[]

  @@index([email])
  @@index([phone])
  @@index([createdAt])
  @@index([userId])
}

model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  name  String
  image String?

  attributes Json

  quantity Int
  price    Int

  @@index([orderId])
  @@index([productId]) // ✅ NEW
}

model OrderStatusHistory {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  status    OrderStatus
  createdAt DateTime    @default(now())

  @@index([orderId])
  @@index([orderId, createdAt])
}

//////////////////////
// ADDRESS
//////////////////////

model Address {
  id String @id @default(cuid())

  fullName   String
  line1      String
  line2      String?
  landmark   String?
  city       String
  state      String
  postalCode String?
  country    String

  createdAt DateTime @default(now())

  orders Order[]
}

//////////////////////
// FRAUD
//////////////////////

model FraudEvent {
  id String @id @default(cuid())

  orderId String?
  ip      String?
  email   String?

  signal   String
  metadata Json?

  createdAt DateTime @default(now())

  @@index([email])
  @@index([ip])
  @@index([createdAt])
}

model AuditEvent {
  id        String   @id @default(cuid())
  userId    String?  // null for anonymous
  actorType String   // "USER" | "SYSTEM" | "ADMIN" | "JOB"
  action    String   // "ORDER_CREATED", "PAYMENT_CONFIRMED", "LOGIN", "PROFILE_UPDATED"
  resource  String?  // "order", "user", "product"
  resourceId String? // "orderId", "userId", etc.

  ip        String?
  userAgent String?

  metadata  Json?    // flexible payload (before/after, diffs, context)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([resource, resourceId])
  @@index([createdAt])
}

model AlertRule {
  id        String   @id @default(cuid())
  name      String
  event     String   // e.g. "AUTH_LOGIN_FAILED"
  threshold Int?     // e.g. 5 failures
  windowSec Int?     // e.g. 600 seconds
  enabled   Boolean  @default(true)

  notifyEmail   String?
  notifyWebhook String?
  notifyWhatsApp String?

  createdAt DateTime @default(now())
}

