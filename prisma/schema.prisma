generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum Role {
  ADMIN
  USER
}

enum PaymentMethod {
  PAYSTACK
  MONNIFY
  BANK_TRANSFER
  COD
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ShipmentStatus {
  PROCESSING
  SHIPPED
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum AddressType {
  SHIPPING
  BILLING
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSED
}

enum PaymentEventType {
  WEBHOOK_RECEIVED
  PAYMENT_VERIFIED
  PAYMENT_FAILED
}

enum InventoryReason {
  SALE
  RESTOCK
  ADJUSTMENT
  REFUND
}

//////////////////////////////////////////////////////
// MODELS
//////////////////////////////////////////////////////

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  phone     String?  @db.VarChar(20)
  password  String?
  role      Role     @default(USER)

  orders    Order[]
  reviews   Review[]
  addresses Address[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([email])
}

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?

  price         Int
  salePrice     Int?

  category      String?
  brand         String?

  isNew         Boolean  @default(false)

  deletedAt     DateTime?

  weightGrams   Int?
  lengthMm      Int?
  widthMm       Int?
  heightMm      Int?

  metadata      Json?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  images        ProductImage[]
  reviews       Review[]
  orderItems    OrderItem[]
  variants      ProductVariant[]
  inventoryMoves InventoryMovement[]

  @@unique([slug, deletedAt])
  @@index([isNew])
  @@index([deletedAt])
  @@index([createdAt])
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  sku       String?  @unique
  size      String?
  color     String?
  stock     Int      @default(0)

  metadata  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product  @relation(fields: [productId], references: [id])
  orderItems OrderItem[]
  inventoryMoves InventoryMovement[]

  @@index([productId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  position  Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product  @relation(fields: [productId], references: [id])

  @@index([productId])
}

model Order {
  id             String        @id @default(cuid())
  userId         String?
  user           User?         @relation(fields: [userId], references: [id])

  email          String
  phone          String?       @db.VarChar(20)

  paymentMethod  PaymentMethod
  paymentStatus  PaymentStatus @default(PENDING)
  orderStatus    OrderStatus   @default(PENDING)

  providerRef    String?       @unique

  total          Int
  currency       String        @default("NGN") @db.VarChar(3)

  // Nigeria-ready shipping fields
  shippingType   String?
  address        String?
  city           String?
  state          String?
  landmark       String?

  cartSnapshot   Json?
  metadata       Json?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  items          OrderItem[]
  shipments      Shipment[]
  refundRequests RefundRequest[]
  paymentEvents  PaymentEvent[]

  @@index([userId])
  @@index([paymentStatus])
  @@index([orderStatus])
  @@index([createdAt])
  @@index([email, createdAt])
}

model OrderItem {
  id           String   @id @default(cuid())
  orderId      String
  productId    String?
  variantId    String?

  quantity     Int
  price        Int

  // Snapshot (source of truth)
  productName  String
  productImage String?
  variantLabel String?

  metadata     Json?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  order        Order          @relation(fields: [orderId], references: [id])
  product      Product?       @relation(fields: [productId], references: [id])
  variant      ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model Address {
  id        String      @id @default(cuid())
  userId    String?

  fullName  String
  phone     String      @db.VarChar(20)
  state     String
  city      String
  lga       String?
  landmark  String?

  address   String
  type      AddressType @default(SHIPPING)

  metadata  Json?

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  deletedAt DateTime?

  user      User?       @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String

  rating    Int
  comment   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
  @@index([productId])
}

model RefundRequest {
  id        String       @id @default(cuid())
  orderId   String

  reason    String
  status    RefundStatus @default(PENDING)

  metadata  Json?

  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  order     Order        @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model PaymentEvent {
  id        String           @id @default(cuid())
  orderId   String
  reference String
  type      PaymentEventType
  payload   Json?

  createdAt DateTime @default(now())

  order     Order    @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([reference])
}

model Shipment {
  id             String         @id @default(cuid())
  orderId        String

  courier        String?
  trackingNumber String?
  status         ShipmentStatus

  metadata       Json?

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  order          Order          @relation(fields: [orderId], references: [id])
  updates        ShipmentUpdate[]

  @@index([orderId])
  @@index([trackingNumber])
}

model ShipmentUpdate {
  id         String         @id @default(cuid())
  shipmentId String

  status     ShipmentStatus
  note       String?

  createdAt  DateTime       @default(now())

  shipment   Shipment       @relation(fields: [shipmentId], references: [id])

  @@index([shipmentId])
}

model DeliveryZone {
  id        String   @id @default(cuid())
  state     String
  lga       String?
  fee       Int

  metadata  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([state])
  @@index([lga])
}

model InventoryMovement {
  id        String   @id @default(cuid())
  productId String
  variantId String?

  change    Int
  reason    InventoryReason
  metadata  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product         @relation(fields: [productId], references: [id])
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([productId])
  @@index([variantId])
}
