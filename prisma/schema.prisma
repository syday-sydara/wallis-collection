generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUMS
//////////////////////

enum UserRole {
  USER
  ADMIN
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderStatus {
  CREATED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum Currency {
  NGN
  USD
  EUR
}

enum PaymentMethod {
  CARD
  TRANSFER
  CASH
}

//////////////////////
// USER
//////////////////////

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      UserRole @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
}

//////////////////////
// PRODUCT CATALOG
//////////////////////

model Product {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?

  basePrice Int?   // optional if variants exist

  isArchived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images   ProductImage[]
  variants ProductVariant[]
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int     @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model ProductVariant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id])

  name  String
  sku   String @unique
  price Int
  stock Int @default(0)

  attributes Json?
}

//////////////////////
// ORDERS
//////////////////////

model Order {
  id        String   @id @default(cuid())

  email     String
  phone     String
  fullName  String

  subtotal  Int
  shippingCost Int
  discountAmount Int? @default(0)
  total     Int

  currency  String   @default("NGN")

  paymentMethod String
  paymentStatus PaymentStatus
  orderStatus   OrderStatus

  paymentReference     String?
  transactionReference String?

  shippingType String

  addressId String?
  address   Address? @relation(fields: [addressId], references: [id])

  cartSnapshot Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String?
  user   User? @relation(fields: [userId], references: [id])

  items OrderItem[]
  orders Order[]

}

model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order @relation(fields: [orderId], references: [id])

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  name       String
  image      String?
  attributes Json?

  quantity Int
  price    Int
}

//////////////////////
// ADDRESS
//////////////////////

model Address {
  id String @id @default(cuid())

  fullName   String
  phone      String
  line1      String
  line2      String?
  landmark   String?
  city       String
  state      String
  lga        String?
  postalCode String?
  country    String

  deliveryInstructions String?

  createdAt DateTime @default(now())

  orders Order[]
}

//////////////////////
// AUDIT (LIGHTWEIGHT)
//////////////////////

model AuditEvent {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])

  action    String
  resource  String?
  resourceId String? @db.Uuid

  metadata  Json?

  createdAt DateTime @default(now())
}

model StockLog {
  id        String   @id @default(cuid())
  variantId String
  change    Int
  reason    String?
  createdAt DateTime @default(now())
  variant   ProductVariant @relation(fields: [variantId], references: [id])

}
